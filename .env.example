# Cloudflare dashboard → Calls → TURN → Create API token
CF_TURN_APP_ID=your-turn-app-id
CF_TURN_APP_TOKEN=your-turn-app-token

# Optional overrides
# TURN_SERVER=cloudflare         # or "coturn" to use local coturn as control
# REPRO_ITERATIONS=20
# REPRO_PORT_RANGE_START=50000
# REPRO_PORT_RANGE_SIZE=5

# coturn (only read when TURN_SERVER=coturn):
# COTURN_URL=turn:127.0.0.1:3478?transport=udp
# COTURN_USERNAME=repro
# COTURN_CREDENTIAL=repro
